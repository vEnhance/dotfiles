unalternates *
alternates '@evanchen\.cc' '^evanchen@mit\.edu$'

set folder=~/Mail/records/
set header_cache=~/.cache/mutt/records

set smtp_url=`echo smtps://$(jq -r ".user2" ~/secrets/mail-users.json)@gmail.com@smtp.gmail.com:465`
set smtp_pass = `secret-tool lookup user $(jq -r ".user2" ~/secrets/mail-users.json) type gmail`
set from = `echo $(jq -r ".user2" ~/secrets/mail-users.json)@gmail.com`
unmy_hdr Bcc

set imap_user = `echo $(jq -r ".user2" ~/secrets/mail-users.json)@gmail.com`
set imap_pass = `secret-tool lookup user $(jq -r ".user2" ~/secrets/mail-users.json) type gmail`
set spoolfile = +Inbox
set postponed = +Drafts

color indicator  brightwhite red
color status     brightwhite red

color sidebar_divider red white
# vim: ft=neomuttrc
