unalternates *
# no alternates for this address

set folder=~/Mail/personal/
set header_cache=~/.cache/mutt/personal

set smtp_url = `echo smtps://$(jq -r ".user0" ~/secrets/mail-users.json)@gmail.com@smtp.gmail.com:465`
set smtp_pass = `secret-tool lookup user $(jq -r ".user0" ~/secrets/mail-users.json) type gmail`
set from = `echo $(jq -r ".user0" ~/secrets/mail-users.json)@gmail.com`
unmy_hdr bcc

set imap_user = `echo $(jq -r ".user0" ~/secrets/mail-users.json)@gmail.com`
set imap_pass = `secret-tool lookup user $(jq -r ".user0" ~/secrets/mail-users.json) type gmail`
set spoolfile = +Inbox
set postponed = +Drafts

color indicator  brightwhite  color19
color status     brightyellow color19

color sidebar_divider color19 white
# vim: ft=neomuttrc
